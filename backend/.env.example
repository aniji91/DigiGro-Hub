# Set USE_MYSQL=true to store app data in MySQL instead of JSON files
USE_MYSQL=true

DB_HOST=127.0.0.1
DB_PORT=3306
DB_USER=root
DB_PASSWORD=
DB_NAME=employee_managment_app

# Server
PORT=5000
NODE_ENV=development

JWT_SECRET=change-this-in-production

# Optional: restrict CORS when frontend is on a different domain
# FRONTEND_URL=https://yourdomain.com
