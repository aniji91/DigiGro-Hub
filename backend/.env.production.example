# Hostinger production — add these in hPanel → Environment Variables (do NOT commit real values)

USE_MYSQL=true
DB_HOST=localhost
DB_PORT=3306
DB_USER=your_hpanel_db_user
DB_PASSWORD=your_hpanel_db_password
DB_NAME=your_hpanel_db_name

PORT=3000
NODE_ENV=production
JWT_SECRET=use-a-long-random-string-here
